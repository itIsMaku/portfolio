---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import RepoNav from "@/components/RepoNav.astro";
import Sidebar from "@/components/Sidebar.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  title?: string;
}

const { title = "itismaku/portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Portfolio of Adam Volkman - Full-stack developer specializing in Java & TypeScript ecosystems."
    />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      const theme = localStorage.getItem("theme") || "dark";
      document.documentElement.setAttribute("data-theme", theme);
    </script>
  </head>
  <body class="bg-gh-canvas text-gh-fg text-sm leading-normal">
    <Header />
    <RepoNav />
    <main class="max-w-[1280px] mx-auto px-6 pt-6 pb-12">
      <div class="flex gap-6 max-lg:flex-col">
        <div class="flex-1 min-w-0">
          <slot />
        </div>
        <aside class="w-[296px] shrink-0 max-lg:w-full">
          <Sidebar />
        </aside>
      </div>
    </main>
    <Footer />
  </body>
</html>
