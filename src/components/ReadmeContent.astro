---
import { SITE, TOOLS, LANGUAGES } from "@/lib/site-data";

const frameworks = TOOLS.filter((t) => t.category === "framework");
const databases = TOOLS.filter((t) => t.category === "database");
const devops = TOOLS.filter((t) => t.category === "devops");
---

<div class="border border-gh-border rounded-md mt-4 overflow-hidden">
  <div
    class="flex items-center gap-2 px-4 py-2 bg-gh-canvas-subtle border-b border-gh-border text-sm font-semibold text-gh-fg"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 16 16"
      fill="currentColor"
      class="text-gh-fg-muted"
    >
      <path
        d="M0 1.75A.75.75 0 0 1 .75 1h4.253c1.227 0 2.317.59 3 1.501A3.743 3.743 0 0 1 11.006 1h4.245a.75.75 0 0 1 .75.75v10.5a.75.75 0 0 1-.75.75h-4.507a2.25 2.25 0 0 0-1.591.659l-.622.621a.75.75 0 0 1-1.06 0l-.622-.621A2.25 2.25 0 0 0 5.258 13H.75a.75.75 0 0 1-.75-.75Zm7.251 10.324.004-5.073-.002-2.253A2.25 2.25 0 0 0 5.003 2.5H1.5v9h3.757a3.75 3.75 0 0 1 1.994.574ZM8.755 4.75l-.004 7.322a3.752 3.752 0 0 1 1.992-.572H14.5v-9h-3.495a2.25 2.25 0 0 0-2.25 2.25Z"
      ></path>
    </svg>
    <span>README.md</span>
  </div>
  <article class="p-8 text-base leading-relaxed text-gh-fg">
    <h1
      class="text-[2em] font-semibold border-b border-gh-border-muted pb-[0.3em] mb-4"
    >
      Hi there, I'm Adam 👋
    </h1>

    <p class="mb-4">
      Full-stack developer passionate about building modern full-stack apps with <strong
        >React</strong
      > &amp; <strong>Next.js</strong>
      and robust backends with <strong>Java</strong> &amp; <strong
        >Spring Boot</strong
      >
    </p>

    <h2
      class="text-[1.5em] font-semibold border-b border-gh-border-muted pb-[0.3em] mt-6 mb-4"
    >
      🛠 Tech Stack
    </h2>

    <h3 class="text-[1.25em] font-semibold mt-5 mb-3">Languages</h3>
    <div class="flex flex-wrap gap-1.5 mb-4">
      {
        LANGUAGES.map((lang) => (
          <span
            class="inline-block px-3 py-1 text-[13px] font-medium bg-gh-canvas-subtle border border-gh-border rounded-md text-gh-fg"
            style={`border-left: 3px solid ${lang.color};`}
          >
            {lang.name}
          </span>
        ))
      }
    </div>

    <h3 class="text-[1.25em] font-semibold mt-5 mb-3">
      Frameworks &amp; Libraries
    </h3>
    <div class="flex flex-wrap gap-1.5 mb-4">
      {
        frameworks.map((tool) => (
          <span class="inline-block px-3 py-1 text-[13px] font-medium bg-gh-canvas-subtle border border-gh-border rounded-md text-gh-fg">
            {tool.name}
          </span>
        ))
      }
    </div>

    <h3 class="text-[1.25em] font-semibold mt-5 mb-3">Databases</h3>
    <div class="flex flex-wrap gap-1.5 mb-4">
      {
        databases.map((tool) => (
          <span class="inline-block px-3 py-1 text-[13px] font-medium bg-gh-canvas-subtle border border-gh-border rounded-md text-gh-fg">
            {tool.name}
          </span>
        ))
      }
    </div>

    <h3 class="text-[1.25em] font-semibold mt-5 mb-3">
      DevOps &amp; Infrastructure
    </h3>
    <div class="flex flex-wrap gap-1.5 mb-4">
      {
        devops.map((tool) => (
          <span class="inline-block px-3 py-1 text-[13px] font-medium bg-gh-canvas-subtle border border-gh-border rounded-md text-gh-fg">
            {tool.name}
          </span>
        ))
      }
    </div>

    <h2
      class="text-[1.5em] font-semibold border-b border-gh-border-muted pb-[0.3em] mt-6 mb-4"
    >
      📫 Get in Touch
    </h2>
    <ul class="pl-8 mb-4">
      <li class="mb-1">
        🐙 GitHub: <a href={SITE.github} class="text-gh-accent hover:underline"
          >@{SITE.username}</a>
      </li>
      <li class="mb-1">
        💼 LinkedIn: <a
          href={SITE.linkedin}
          class="text-gh-accent hover:underline">Adam Volkman</a>
      </li>
      <li class="mb-1">
        🐦 X: <a href={SITE.twitter} class="text-gh-accent hover:underline"
          >@just_makuu</a>
      </li>
      <li class="mb-1">
        📷 Instagram: <a
          href={SITE.instagram}
          class="text-gh-accent hover:underline">@a._.volkman</a>
      </li>
    </ul>
  </article>
</div>
