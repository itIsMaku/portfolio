---
import { Image } from "astro:assets";
import { SITE, LANGUAGES, TOOLS, CONTRIBUTORS } from "@/lib/site-data";
import LanguageBar from "@/components/LanguageBar.astro";
---

<div class="flex flex-col gap-4">
  <!-- About -->
  <section class="pb-4 border-b border-gh-border-muted">
    <h2 class="text-sm font-semibold text-gh-fg mb-2 flex items-center gap-1.5">
      About
    </h2>
    <p class="text-sm text-gh-fg mb-3 leading-normal">{SITE.description}</p>
    <div class="flex flex-col gap-1 mb-3">
      <a
        href={`https://${SITE.domain}`}
        class="flex items-center gap-1.5 text-gh-fg-muted text-sm no-underline hover:text-gh-accent"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="currentColor"
        >
          <path
            d="m7.775 3.275 1.25-1.25a3.5 3.5 0 1 1 4.95 4.95l-2.5 2.5a3.5 3.5 0 0 1-4.95 0 .751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018 1.998 1.998 0 0 0 2.83 0l2.5-2.5a2.002 2.002 0 0 0-2.83-2.83l-1.25 1.25a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042Zm-4.69 9.64a1.998 1.998 0 0 0 2.83 0l1.25-1.25a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042l-1.25 1.25a3.5 3.5 0 1 1-4.95-4.95l2.5-2.5a3.5 3.5 0 0 1 4.95 0 .751.751 0 0 1-.018 1.042.751.751 0 0 1-1.042.018 1.998 1.998 0 0 0-2.83 0l-2.5 2.5a1.998 1.998 0 0 0 0 2.83Z"
          ></path>
        </svg>
        {SITE.domain}
      </a>
    </div>
    <div class="flex flex-wrap ml-1 gap-1">
      {
        TOOLS.map((tool) => (
          <span class="inline-block text-xs font-medium px-2.5 py-0.5 bg-gh-topic-bg text-gh-topic-text rounded-full cursor-default leading-[22px]">
            {tool.name.toLowerCase().replace(/[\s\/]/g, "-")}
          </span>
        ))
      }
    </div>

    <!-- Stats -->
    <div class="pt-4">
      <div class="flex flex-col gap-3 flex-wrap">
        <span
          class="flex items-center gap-1 text-gh-fg-muted text-xs no-underline"
          id="watcher-stat"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="currentColor"
          >
            <path
              d="M8 2c1.981 0 3.671.992 4.933 2.078 1.27 1.091 2.187 2.345 2.637 3.023a1.62 1.62 0 0 1 0 1.798c-.45.678-1.367 1.932-2.637 3.023C11.67 13.008 9.981 14 8 14c-1.981 0-3.671-.992-4.933-2.078C1.797 10.83.88 9.576.43 8.898a1.62 1.62 0 0 1 0-1.798c.45-.677 1.367-1.931 2.637-3.022C4.33 2.992 6.019 2 8 2ZM1.679 7.932a.12.12 0 0 0 0 .136c.411.622 1.241 1.75 2.366 2.717C5.176 11.758 6.527 12.5 8 12.5c1.473 0 2.825-.742 3.955-1.715 1.124-.967 1.954-2.096 2.366-2.717a.12.12 0 0 0 0-.136c-.412-.621-1.242-1.75-2.366-2.717C10.824 4.242 9.473 3.5 8 3.5c-1.473 0-2.824.742-3.955 1.715-1.124.967-1.954 2.096-2.366 2.717ZM8 10a2 2 0 1 1-.001-3.999A2 2 0 0 1 8 10Z"
            ></path>
          </svg>
          <span class="font-semibold text-gh-fg" id="watcher-count">0</span>
          <span class="font-normal text-gh-fg-muted">watching</span>
        </span>
        <a
          href={SITE.githubRepo}
          class="flex items-center gap-1 text-gh-fg-muted text-xs no-underline hover:text-gh-accent hover:no-underline"
          target="_blank"
          rel="noopener"
          id="star-stat"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="currentColor"
          >
            <path
              d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Zm0 2.445L6.615 5.5a.75.75 0 0 1-.564.41l-3.097.45 2.24 2.184a.75.75 0 0 1 .216.664l-.528 3.084 2.769-1.456a.75.75 0 0 1 .698 0l2.77 1.456-.53-3.084a.75.75 0 0 1 .216-.664l2.24-2.183-3.096-.45a.75.75 0 0 1-.564-.41L8 2.694Z"
            ></path>
          </svg>
          <span class="font-semibold text-gh-fg" id="star-count">0</span>
          <span class="font-normal text-gh-fg-muted">stars</span>
        </a>
        <a
          href={`${SITE.githubRepo}/fork`}
          class="flex items-center gap-1 text-gh-fg-muted text-xs no-underline hover:text-gh-accent hover:no-underline"
          target="_blank"
          rel="noopener"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="currentColor"
          >
            <path
              d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 1 1.5 0v.878a2.25 2.25 0 0 1-2.25 2.25h-1.5v2.128a2.251 2.251 0 1 1-1.5 0V8.5h-1.5A2.25 2.25 0 0 1 3.5 6.25v-.878a2.25 2.25 0 1 1 1.5 0ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm6.75.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm-3 8.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z"
            ></path>
          </svg>
          <span class="font-semibold text-gh-fg">0</span>
          <span class="font-normal text-gh-fg-muted">forks</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Releases -->
  <section class="pb-4 border-b border-gh-border-muted">
    <h2 class="text-sm font-semibold text-gh-fg mb-2 flex items-center gap-1.5">
      Releases
      <span
        class="text-xs px-1.5 bg-gh-counter rounded-full min-w-5 text-center leading-[18px] font-normal text-gh-fg"
        >1</span
      >
    </h2>
    <div class="flex items-center gap-2">
      <a
        href={`${SITE.githubRepo}/releases`}
        class="flex items-center gap-1 text-gh-accent text-sm font-semibold"
        target="_blank"
        rel="noopener"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="currentColor"
          class="text-gh-success"
        >
          <path
            d="M1 7.775V2.75C1 1.784 1.784 1 2.75 1h5.025c.464 0 .91.184 1.238.513l6.25 6.25a1.75 1.75 0 0 1 0 2.474l-5.026 5.026a1.75 1.75 0 0 1-2.474 0l-6.25-6.25A1.752 1.752 0 0 1 1 7.775Zm1.5 0c0 .066.026.13.073.177l6.25 6.25a.25.25 0 0 0 .354 0l5.025-5.025a.25.25 0 0 0 0-.354l-6.25-6.25a.25.25 0 0 0-.177-.073H2.75a.25.25 0 0 0-.25.25ZM6 5a1 1 0 1 1 0 2 1 1 0 0 1 0-2Z"
          ></path>
        </svg>
        <span id="release-version">v1.0.0</span>
      </a>
      <span
        class="text-xs font-medium px-[7px] bg-gh-btn-primary text-gh-fg-on-emphasis rounded-full leading-[22px]"
        >Latest</span
      >
    </div>
  </section>

  <!-- Contributors -->
  <section class="pb-4 border-b border-gh-border-muted">
    <h2 class="text-sm font-semibold text-gh-fg mb-2 flex items-center gap-1.5">
      Contributors
      <span
        class="text-xs px-1.5 bg-gh-counter rounded-full min-w-5 text-center leading-[18px] font-normal text-gh-fg"
        >{CONTRIBUTORS.length}</span
      >
    </h2>
    <div class="flex flex-wrap gap-1">
      {
        CONTRIBUTORS.map((contributor) => (
          <a
            href={`/projects/${contributor.slug}`}
            class="block rounded-full overflow-hidden w-8 h-8 border border-gh-border transition-opacity hover:opacity-80"
            title={contributor.name}
          >
            <Image
              src={contributor.logo}
              alt={contributor.name}
              width={32}
              height={32}
              loading="eager"
              class="w-full h-full object-cover"
            />
          </a>
        ))
      }
    </div>
  </section>

  <!-- Languages -->
  <section>
    <h2 class="text-sm font-semibold text-gh-fg mb-2 flex items-center gap-1.5">
      Languages
    </h2>
    <LanguageBar />
  </section>
</div>

<script>
  import { SITE } from "@/lib/site-data";

  async function fetchStars() {
    try {
      const res = await fetch(
        `https://api.github.com/repos/${SITE.username}/${SITE.repoName}`,
      );
      if (!res.ok) return;
      const data = await res.json();
      const el = document.getElementById("star-count");
      if (el) el.textContent = String(data.stargazers_count ?? 0);
    } catch {}
  }

  async function updateVisitorCount() {
    const el = document.getElementById("watcher-count");
    if (!el) return;
    try {
      const res = await fetch("/api/visit?record");
      if (!res.ok) return;
      const data = await res.json();
      el.textContent = String(data.count);
    } catch {}
  }

  fetchStars();
  updateVisitorCount();
</script>
