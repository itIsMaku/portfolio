---
import { SITE } from "@/lib/site-data";

interface Props {
  breadcrumbs?: { name: string; path: string }[];
}

const { breadcrumbs } = Astro.props;
---

<div class="flex items-center justify-between mb-4 gap-4 flex-wrap max-md:flex-col max-md:items-start">
  <div class="flex items-center gap-2">
    <button class="flex items-center gap-1 px-3 py-[3px] text-sm font-medium text-gh-fg bg-gh-btn-bg border border-gh-btn-border rounded-md cursor-default font-[inherit] [&_svg]:shrink-0" disabled>
      <svg aria-hidden="true" focusable="false" viewBox="0 0 16 16" width="16" height="16" fill="currentColor" style="vertical-align:text-bottom"><path d="M9.5 3.25a2.25 2.25 0 1 1 3 2.122V6A2.5 2.5 0 0 1 10 8.5H6a1 1 0 0 0-1 1v1.128a2.251 2.251 0 1 1-1.5 0V5.372a2.25 2.25 0 1 1 1.5 0v1.836A2.493 2.493 0 0 1 6 7h4a1 1 0 0 0 1-1v-.628A2.25 2.25 0 0 1 9.5 3.25Zm-6 0a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Zm8.25-.75a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5ZM4.25 12a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Z"></path></svg>
      <span>{SITE.defaultBranch}</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="currentColor" class="opacity-60">
        <path d="m4.427 7.427 3.396 3.396a.25.25 0 0 0 .354 0l3.396-3.396A.25.25 0 0 0 11.396 7H4.604a.25.25 0 0 0-.177.427Z"></path>
      </svg>
    </button>

    {breadcrumbs && breadcrumbs.length > 0 && (
      <nav class="flex items-center gap-1 text-sm" aria-label="Breadcrumb">
        <a href="/" class="text-gh-accent font-semibold">{SITE.repoName}</a>
        {breadcrumbs.map((crumb, i) => (
          <Fragment>
            <span class="text-gh-fg-muted">/</span>
            {i === breadcrumbs.length - 1 ? (
              <span class="text-gh-fg font-semibold">{crumb.name}</span>
            ) : (
              <a href={crumb.path} class="text-gh-accent font-semibold">{crumb.name}</a>
            )}
          </Fragment>
        ))}
      </nav>
    )}
  </div>

  <div class="flex items-center gap-2 max-md:w-full max-md:justify-end">
    <a href={SITE.githubRepo} class="inline-flex items-center gap-1 px-3 py-[3px] text-xs font-medium rounded-md border border-gh-btn-border bg-gh-btn-bg text-gh-fg no-underline leading-5 whitespace-nowrap hover:bg-gh-btn-hover hover:no-underline" target="_blank" rel="noopener" title="View on GitHub">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
        <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.249.249 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z"></path>
      </svg>
      <span>Go to file</span>
    </a>
    <a href={`${SITE.githubRepo}/archive/refs/heads/main.zip`} class="inline-flex items-center gap-1 px-3 py-[3px] text-xs font-medium rounded-md border border-[rgba(27,31,36,0.15)] bg-gh-btn-primary text-gh-fg-on-emphasis no-underline leading-5 whitespace-nowrap hover:bg-gh-btn-primary-hover hover:no-underline" target="_blank" rel="noopener">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
        <path d="m11.28 3.22 4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.749.749 0 0 1-1.275-.326.749.749 0 0 1 .215-.734L13.94 8l-3.72-3.72a.749.749 0 0 1 .326-1.275.749.749 0 0 1 .734.215Zm-6.56 0a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042L2.06 8l3.72 3.72a.749.749 0 0 1-.326 1.275.749.749 0 0 1-.734-.215L.47 8.53a.75.75 0 0 1 0-1.06Z"></path>
      </svg>
      <span>Code</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="currentColor" class="opacity-60">
        <path d="m4.427 7.427 3.396 3.396a.25.25 0 0 0 .354 0l3.396-3.396A.25.25 0 0 0 11.396 7H4.604a.25.25 0 0 0-.177.427Z"></path>
      </svg>
    </a>
  </div>
</div>
